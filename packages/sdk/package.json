    "./cookies": { "types": "./cookies.d.ts" },
    "./damage": { "types": "./damage.d.ts" },
    "./db": { "types": "./db.d.ts" },
    "./entity": { "types": "./entity.d.ts" },
    "./events": { "types": "./events.d.ts" },
    "./frame": { "types": "./frame.d.ts" },
    "./http": { "types": "./http.d.ts" },
