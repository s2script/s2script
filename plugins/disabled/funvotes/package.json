{
  "name": "@s2script/funvotes",
  "version": "0.1.0",
  "private": true,
  "main": "src/plugin.ts",
  "s2script": {
    "config": {
      "funvote_duration": {
        "type": "int",
        "default": 20,
        "description": "Seconds a funvote (AllTalk/FriendlyFire/Gravity/Slay) stays open."
      },
      "funvote_ratio": {
        "type": "float",
        "default": 0.6,
        "description": "Fraction of votes cast that must be Yes for a funvote to pass (SM behavior; 0.6 = 60%)."
      },
      "funvote_show_tally": {
        "type": "bool",
        "default": true,
        "description": "Show the live center-screen tally during a funvote."
      }
    }
  }
}
